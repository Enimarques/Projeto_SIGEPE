[ req ]
default_bits       = 2048
distinguished_name = req_distinguished_name
req_extensions     = req_ext
prompt             = no

[ req_distinguished_name ]
C  = BR
ST = PA
L  = Parauapebas
O  = Camara Municipal
OU = TI
CN = 192.168.1.11

[ req_ext ]
subjectAltName = @alt_names

[ alt_names ]
IP.1 = 192.168.1.11
